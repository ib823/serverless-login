# Upstash Redis (GET NEW CREDENTIALS FROM UPSTASH CONSOLE)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WebAuthn Relying Party
RP_NAME=Passkeys IdP
RP_ID=your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# RS256 keys (Generate new ones - see commands below)
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# OAuth client(s) 
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URIS=

# Token lifetimes
ACCESS_TOKEN_TTL_SEC=3600
REFRESH_TOKEN_TTL_SEC=1209600

# Metrics (Generate new secret below)
METRICS_BEARER=

# Security Keys (Generate these)
ENCRYPTION_KEY=
SESSION_SECRET=
CSRF_SECRET=
